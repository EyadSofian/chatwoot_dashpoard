# ─────────────────────────────────────────────────────────────────────────────
# Engosoft Chatwoot Analytics — environment
# Copy to `.env` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# --- Chatwoot connection ------------------------------------------------------
# Base URL of the self-hosted Chatwoot instance (no trailing slash).
CHATWOOT_BASE_URL=https://chat.engosoft.com
# Numeric account id (Engosoft = 2).
CHATWOOT_ACCOUNT_ID=2
# A Chatwoot user access token with admin/agent scope (Profile > Access Token).
CHATWOOT_API_TOKEN=replace-with-user-access-token

# --- Webhook security ---------------------------------------------------------
# Shared secret used to authenticate the Chatwoot webhook into this app.
# If set, the webhook must send it as `?token=` / `x-webhook-secret` header,
# OR sign the body with the Chatwoot HMAC signature (x-chatwoot-signature).
# Leave empty to accept unauthenticated webhooks (NOT recommended in production).
WEBHOOK_SECRET=replace-with-webhook-secret
# Optional: reject signed webhooks older than N seconds (0 = no age check).
WEBHOOK_MAX_AGE_SECONDS=0

# --- Database -----------------------------------------------------------------
# PostgreSQL connection string. Railway provides this automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/chatwoot_analytics?schema=public

# --- Campaign uploader apps ---------------------------------------------------
# Base URLs of the two campaign uploader apps (chatwoot-campain-uploder).
# Each must expose GET /api/jobs. No trailing slash.
CAMPAIGN_SALES_APP_URL=https://sales-campaigns.example.com
CAMPAIGN_OPERATIONS_APP_URL=https://ops-campaigns.example.com
# Optional shared secret sent to the campaign apps as `x-webhook-secret`.
CAMPAIGN_APPS_API_SECRET=

# --- App authentication -------------------------------------------------------
# Single manager login for the dashboard.
APP_USERNAME=admin
APP_PASSWORD=replace-with-strong-password
# Optional dedicated secret for signing the session cookie. If empty a key is
# derived from APP_PASSWORD + WEBHOOK_SECRET.
SESSION_SECRET=

# --- Locale / time ------------------------------------------------------------
TIMEZONE=Africa/Cairo

# --- SLA defaults (can also be changed in the Settings screen) ----------------
# First-response target in minutes; resolution target in hours.
SLA_FIRST_RESPONSE_MINUTES=30
SLA_RESOLUTION_HOURS=24
# Business hours (24h clock) and working days (0=Sunday .. 6=Saturday).
BUSINESS_START=09:00
BUSINESS_END=22:00
BUSINESS_DAYS=0,1,2,3,4,5,6

# --- Fahd / Botpress bot detection --------------------------------------------
# Label that marks a bot-managed conversation (Fahd). Used to detect bot handoffs.
BOT_LABEL=needs-bot
# Inbox ids handled by the Fahd bot (comma separated). Optional.
BOT_INBOX_IDS=27
# Chatwoot agent/user ids that are actually bots (Fahd). Messages from these
# senders are NOT counted as human replies. Comma separated. Optional.
BOT_AGENT_IDS=

# --- Department team mapping (mirror of Chatwoot-Actions) ----------------------
# Used to infer department from the assigned team when the engosoft_department
# custom attribute is missing.
DEPARTMENT_SALES_TEAM_ID=4
DEPARTMENT_OPERATIONS_TEAM_ID=3
DEPARTMENT_COMPLAINTS_TEAM_ID=

# --- Optional: cron secret to protect scheduled sync endpoints ----------------
# If set, POST /api/backfill and /api/sync/campaigns also accept this as a
# bearer token (for Railway cron / external schedulers) in addition to a session.
CRON_SECRET=
