// Engosoft Chatwoot Analytics — data model.
//
// Design goals:
//  - Raw events are stored verbatim so every metric can be recomputed later.
//  - Normalized tables are idempotent: duplicate webhooks/backfills upsert on
//    stable natural keys (chatwootId, dedupeKey) and never double-count.
//  - Heavy read paths (Overview, Conversations table) read denormalized metric
//    columns on `conversations`, filled by the metrics engine — no need to load
//    all messages on every request.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Raw ingestion ──────────────────────────────

/// Every inbound webhook + every backfilled entity page is stored raw.
model RawEvent {
  id          BigInt   @id @default(autoincrement())
  source      String // "chatwoot_webhook" | "chatwoot_backfill" | "campaign_app"
  event       String? // e.g. message_created, conversation_status_changed
  dedupeKey   String   @unique // stable hash so duplicate deliveries are idempotent
  signatureOk Boolean  @default(false)
  conversationCwId Int?
  messageCwId      Int?
  occurredAt  DateTime?
  receivedAt  DateTime @default(now())
  processedAt DateTime?
  processError String?
  payload     Json

  @@index([source, event])
  @@index([conversationCwId])
  @@index([receivedAt])
  @@map("raw_events")
}

// ─────────────────────────────── Entities ───────────────────────────────────

model Agent {
  id          Int      @id // chatwoot user id
  name        String?
  email       String?
  role        String?
  availability String?
  thumbnail   String?
  confirmed   Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  memberships TeamMembership[]

  @@map("agents")
}

/// Chatwoot team membership (GET /teams/:id/team_members).
/// An agent can belong to SEVERAL teams, so this is only ever a fallback for
/// team attribution — never the primary truth. See metrics/teamAttribution.ts.
model TeamMembership {
  teamCwId  Int
  agentCwId Int
  createdAt DateTime @default(now())

  team  Team  @relation(fields: [teamCwId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentCwId], references: [id], onDelete: Cascade)

  @@id([teamCwId, agentCwId])
  @@index([agentCwId])
  @@map("team_memberships")
}

model Team {
  id         Int      @id // chatwoot team id
  name       String?
  department String? // derived: sales | operations | complaints | unknown
  updatedAt  DateTime @updatedAt

  memberships TeamMembership[]

  @@map("teams")
}

model Inbox {
  id          Int      @id // chatwoot inbox id
  name        String?
  channelType String?
  department  String? // optional inbox→department hint
  updatedAt   DateTime @updatedAt

  @@map("inboxes")
}

model Contact {
  id         Int      @id // chatwoot contact id
  name       String?
  phone      String?
  email      String?
  identifier String?
  updatedAt  DateTime @updatedAt

  @@index([phone])
  @@map("contacts")
}

// ─────────────────────────────── Conversations ──────────────────────────────

model Conversation {
  id          BigInt @id @default(autoincrement())
  chatwootId  Int    @unique // conversation id
  displayId   Int?
  accountId   Int?

  // Foreign chatwoot ids (kept scalar; entities upserted as stubs on ingest)
  inboxCwId    Int?
  inboxName    String?
  teamCwId     Int?
  teamName     String?
  assigneeCwId Int?
  assigneeName String?
  contactCwId  Int?
  contactName  String?
  contactPhone String?

  // Lifecycle / status
  status            String? // open | pending | resolved | snoozed
  unreadCount       Int      @default(0)
  labels            String[] @default([])
  department        String? // sales | operations | complaints | unknown

  createdAtCw       DateTime? // conversation created
  firstOpenedAt     DateTime?
  lastMessageAt     DateTime?
  lastMessageType   String? // incoming | outgoing | activity | template
  lastActivityAt    DateTime?
  resolvedAt        DateTime?
  snoozedUntil      DateTime?

  // Reply metrics (computed by the metrics engine)
  assignedAt          DateTime? // first human assignment
  firstHumanReplyAt   DateTime? // first public human reply after assignment
  responseSeconds     Int? // assignment → first human reply
  needsReply          Boolean   @default(false)
  handledByHuman      Boolean   @default(false)

  // Duration metrics (sum across lifecycle segments)
  conversationDurationSeconds     Int?
  conversationBusinessSeconds     Int?

  // Campaign correlation
  campaignLabel        String?
  campaignSource       String? // sales | operations
  campaignTemplate     String?
  campaignStatus       String?
  campaignCreatedAt    DateTime?
  isCampaign           Boolean  @default(false)

  // Bot (Fahd) involvement
  botInvolved          Boolean  @default(false)
  botReleaseAt         DateTime?

  // SLA (computed)
  slaFirstResponseState String? // healthy | near_breach | breached
  slaResolutionState    String?
  slaFirstResponseBreached Boolean @default(false)
  slaResolutionBreached    Boolean @default(false)

  customAttributes Json?
  ingestedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages            Message[]
  assignmentIntervals AssignmentInterval[]
  resolutionIntervals ResolutionInterval[]
  responseMetrics     ResponseMetric[]
  campaignReplies     CampaignReply[]
  botHandoffs         BotHandoff[]

  @@index([status])
  @@index([department])
  @@index([assigneeCwId])
  @@index([teamCwId])
  @@index([inboxCwId])
  @@index([lastMessageAt])
  @@index([createdAtCw])
  @@index([isCampaign])
  @@index([needsReply])
  @@index([campaignLabel])
  @@index([assignedAt])
  @@index([firstHumanReplyAt])
  @@index([resolvedAt])
  @@index([slaFirstResponseBreached])
  // The team report's hot path: one team, one window.
  @@index([teamCwId, createdAtCw])
  @@map("conversations")
}

model Message {
  id             BigInt   @id @default(autoincrement())
  chatwootId     Int      @unique
  conversationId BigInt
  conversationCwId Int

  messageType    Int? // 0 incoming, 1 outgoing, 2 activity, 3 template
  contentType    String?
  private        Boolean  @default(false)
  content        String?
  senderType     String? // user | contact | agent_bot | ...
  senderId       Int?
  senderName     String?

  isTemplate     Boolean  @default(false) // WhatsApp campaign template / campaign send
  isAutomation   Boolean  @default(false) // generated by a Chatwoot automation rule
  isBot          Boolean  @default(false) // Fahd/Botpress or agent_bot
  isHumanReply   Boolean  @default(false) // public outgoing human reply

  createdAtCw    DateTime?
  ingestedAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAtCw])
  @@index([conversationCwId])
  @@index([messageType])
  @@map("messages")
}

/// Normalized lifecycle event (assignment, status change, resolve, reopen…).
/// Keyed by conversationCwId only — events can arrive before the conversation
/// row is materialized, so there is no hard FK to conversations.
model ConversationEvent {
  id               BigInt   @id @default(autoincrement())
  conversationCwId Int
  type             String // assigned | unassigned | status_changed | resolved | reopened | team_changed | created
  dedupeKey        String   @unique
  fromValue        String?
  toValue          String?
  actorType        String?
  actorId          Int?
  occurredAt       DateTime

  @@index([conversationCwId, occurredAt])
  @@index([type])
  @@map("conversation_events")
}

/// One interval per human-agent assignment. Reassignment opens a new interval.
model AssignmentInterval {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  conversationCwId Int
  assigneeCwId   Int
  assigneeName   String?
  /// Team the conversation sat in at assignment time. Preserves team history
  /// when a conversation is later moved or un-teamed — attribution source #2.
  teamCwId       Int?
  startedAt      DateTime // when assigned
  endedAt        DateTime? // when reassigned/unassigned/resolved
  firstReplyAt   DateTime? // first public human reply by this assignee after start
  responseSeconds Int?
  responded      Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationCwId, assigneeCwId, startedAt])
  @@index([assigneeCwId, startedAt])
  @@index([teamCwId, startedAt])
  @@map("assignment_intervals")
}

/// First-response metric per conversation (denormalized for agent reports).
model ResponseMetric {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  conversationCwId Int    @unique
  assigneeCwId   Int?
  assignedAt     DateTime?
  firstReplyAt   DateTime?
  responseSeconds Int?
  businessSeconds Int?
  breachedSla    Boolean  @default(false)
  computedAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([assigneeCwId])
  @@map("response_metrics")
}

/// One row per open→resolved lifecycle segment (reopen creates a new segment).
model ResolutionInterval {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  conversationCwId Int
  segmentIndex   Int
  openedAt       DateTime
  resolvedAt     DateTime?
  durationSeconds Int?
  businessSeconds Int?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationCwId, segmentIndex])
  @@index([resolvedAt])
  @@map("resolution_intervals")
}

// ─────────────────────────────── Campaigns ──────────────────────────────────

model CampaignSource {
  id        Int      @id @default(autoincrement())
  key       String   @unique // sales | operations
  name      String
  baseUrl   String?
  updatedAt DateTime @updatedAt

  jobs CampaignJob[]

  @@map("campaign_sources")
}

model CampaignJob {
  id                 BigInt   @id @default(autoincrement())
  sourceId           Int
  sourceKey          String // sales | operations
  jobId              String // uploader job uuid
  type               String? // send | upload
  status             String?
  statusBucket       String? // running | pending | completed | failed | stopped
  operatorName       String?
  queueLabel         String?
  labelName          String?
  originalLabelName  String?
  templateName       String?
  inboxCwId          Int?
  inboxName          String?
  total              Int      @default(0)
  processed          Int      @default(0)
  sent               Int      @default(0)
  failed             Int      @default(0)
  skipped            Int      @default(0)
  errors             Int      @default(0)
  failedRecordsCount Int      @default(0)
  sentTrackCount     Int      @default(0)
  deliveryFailuresCount Int   @default(0)
  createdAtApp       DateTime?
  startedAt          DateTime?
  finishedAt         DateTime?
  active             Boolean  @default(false)
  lastError          String?
  raw                Json?
  syncedAt           DateTime @default(now())
  /// Last time recipients were matched to Chatwoot messages and replies derived.
  reconciledAt       DateTime?

  source     CampaignSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  recipients CampaignRecipient[]
  replies    CampaignReply[]

  @@unique([sourceKey, jobId])
  @@index([sourceKey, createdAtApp])
  @@index([labelName])
  @@index([operatorName])
  @@map("campaign_jobs")
}

model CampaignRecipient {
  id             BigInt   @id @default(autoincrement())
  campaignJobId  BigInt
  sourceKey      String
  jobId          String
  phone          String?
  name           String?
  status         String? // sent | failed | skipped
  conversationCwId Int?
  messageCwId    Int?
  errorCode      String?
  errorDescription String?

  /// created_at of the outbound template message (resolved during reconciliation).
  sentAt           DateTime?
  /// matched | message_missing | no_conversation | not_sent
  correlationState String?

  job     CampaignJob     @relation(fields: [campaignJobId], references: [id], onDelete: Cascade)
  replies CampaignReply[]

  @@unique([campaignJobId, phone])
  @@index([conversationCwId])
  @@index([sourceKey, jobId])
  @@index([campaignJobId, status])
  @@index([messageCwId])
  @@map("campaign_recipients")
}

/// A customer reply to a specific campaign SEND, plus the agent's response time.
///
/// Keyed to the job/recipient that produced it — never to the label. A label is
/// re-used across campaigns and the same customer can be messaged by several, so
/// `[conversationCwId, campaignLabel]` merged rows that were never the same send.
model CampaignReply {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  conversationCwId Int

  /// The send this reply answers. Null only for attribute-fallback rows.
  campaignJobId       BigInt?
  campaignRecipientId BigInt?
  /// Chatwoot id of the outbound template message we measured from.
  campaignMessageCwId Int?
  /// When that template actually left — anything before it is not a reply to it.
  sentAt              DateTime?

  /// message_id (exact) | attribute_fallback (approximate) | unmatched
  correlationMethod String @default("attribute_fallback")
  /// high | low — keeps approximate rows out of the precise numbers.
  confidence        String @default("low")
  /// `job:<jobId>:conv:<id>` or `attr:<conv>:<label>` — makes re-runs idempotent.
  dedupeKey         String @unique

  campaignLabel  String?
  campaignSource String? // sales | operations — from CampaignJob.sourceKey
  template       String?
  replyAt        DateTime? // first public incoming customer message after sentAt
  firstAgentReplyAt DateTime?
  responseSeconds Int? // customer reply → first human agent reply
  assigned       Boolean  @default(false)
  assigneeCwId   Int?
  assigneeName   String?
  updatedAt      DateTime @updatedAt

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  job          CampaignJob?       @relation(fields: [campaignJobId], references: [id], onDelete: SetNull)
  recipient    CampaignRecipient? @relation(fields: [campaignRecipientId], references: [id], onDelete: SetNull)

  @@unique([campaignJobId, conversationCwId])
  @@index([campaignJobId])
  @@index([campaignSource])
  @@index([campaignLabel])
  @@index([correlationMethod])
  @@map("campaign_replies")
}

// ─────────────────────────────── Fahd / Bot ─────────────────────────────────

model BotHandoff {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  conversationCwId Int
  dedupeKey      String   @unique
  handoffAt      DateTime
  reentry        Boolean  @default(false) // resolved re-entry that went to Fahd
  department     String? // routed department
  routedTeamCwId Int?
  queuedUnassigned Boolean @default(false)
  gotAgentReply  Boolean  @default(false)
  firstAgentReplyAt DateTime?
  handoffToReplySeconds Int?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([department])
  @@index([handoffAt])
  @@map("bot_handoffs")
}

// ─────────────────────────────── Ops / settings ─────────────────────────────

model SyncRun {
  id         BigInt   @id @default(autoincrement())
  type       String // backfill | campaign_sync | recompute
  status     String   @default("running") // running | success | error | partial
  params     Json?
  stats      Json?
  error      String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?

  @@index([type, startedAt])
  @@map("sync_runs")
}

/// Key/value app settings (SLA thresholds, business hours overrides…).
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
